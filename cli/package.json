{
  "name": "vitals-cli",
  "version": "0.1.0",
  "description": "VITALS CLI - Performance decision engine for CI/CD",
  "main": "dist/index.js",
  "bin": {
    "vitals": "./bin/vitals"
  },
  "scripts": {
    "build": "tsc -p tsconfig.cli.json",
    "dev": "tsc -p tsconfig.cli.json --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test \"tests/**/*.test.mjs\""
  },
  "keywords": [
    "vitals",
    "cli",
    "performance",
    "regression",
    "ci-cd",
    "observability"
  ],
  "author": "Aniket Raj",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "axios": "^1.14.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
